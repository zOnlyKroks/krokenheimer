# Discord Bot Configuration
BOT_TOKEN=your_discord_bot_token_here
BOT_OWNERS=your_discord_user_id

# LLM Plugin Configuration
# Enable/disable automatic message generation
LLM_ENABLED=true

# Message generation interval (in minutes)
# Bot will post between MIN and MAX randomly
LLM_MIN_INTERVAL_MINUTES=60
LLM_MAX_INTERVAL_MINUTES=180

# Channel scanning interval (in minutes)
# Bot will scan all channels for new messages every N minutes
LLM_SCAN_INTERVAL_MINUTES=2

# Channel filtering (optional)
# Only post in these channels (comma-separated channel IDs)
# LLM_CHANNEL_IDS=123456789,987654321

# Exclude these channels (comma-separated channel IDs)
# LLM_EXCLUDE_CHANNEL_IDS=111111111,222222222

# Ollama LLM Settings
# Available models: llama3.2:3b, llama3.2:8b, mistral:7b
OLLAMA_MODEL=llama3.2:3b

# Temperature controls randomness (0.0 = deterministic, 1.0 = very creative)
OLLAMA_TEMPERATURE=0.9

# Maximum length of generated messages (in tokens, roughly 4 chars per token)
OLLAMA_MAX_TOKENS=200

# Context window size
OLLAMA_CONTEXT_WINDOW=2048
